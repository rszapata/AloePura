{
  "name": "aloe-ecommerce-backend",
  "version": "0.1.0",
  "description": "Backend API for aloe vera e-commerce (Express + PostgreSQL + JWT)",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "migrate": "knex migrate:latest",
    "migrate:rollback": "knex migrate:rollback",
    "seed": "knex seed:run",
    "make-admin": "node scripts/make-admin.js"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "pg": "^8.12.0",
    "stripe": "^17.0.0",
    "zod": "^3.23.8"
  },
  "engines": {
    "node": ">=20"
  }
}
