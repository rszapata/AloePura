# Copia este archivo a .env y rellena los valores
# ---
# En Render, define estas mismas variables en el panel Environment.

# Entorno: development | production | test
NODE_ENV=development

# Puerto HTTP local (Render lo ignora y asigna process.env.PORT)
PORT=5000

# PostgreSQL — conexión completa
# Local:  postgresql://USER:PASS@localhost:5432/aloe_dev
# Render: la URL que te da "Internal Database URL" (privada, misma región)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aloe_dev

# JWT — genera uno con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-use-a-strong-random-64-byte-hex
JWT_EXPIRES_IN=7d

# CORS — lista separada por coma de orígenes permitidos
# Local:  http://localhost:5173
# Prod:   https://tu-frontend.onrender.com,https://tu-dominio.es
CORS_ORIGINS=http://localhost:5173

# Rate limit en /api/auth/*
AUTH_RATE_LIMIT_MAX=10
AUTH_RATE_LIMIT_WINDOW_MS=900000

# Stripe — https://dashboard.stripe.com/test/apikeys
# Deja en blanco para deshabilitar el pago con tarjeta (el backend no fallará).
STRIPE_SECRET_KEY=
# Obtenido tras ejecutar `stripe listen` (CLI) o desde el dashboard del webhook endpoint.
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=eur

# Cloudinary — https://console.cloudinary.com/settings/api-keys
# Sube de imágenes en el panel admin. Dejar en blanco deshabilita el endpoint
# /api/admin/uploads (el admin verá un error 503 al intentar subir).
# API_SECRET NUNCA se expone al navegador: sólo firma peticiones.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=aloepura/products
